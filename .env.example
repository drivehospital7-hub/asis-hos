# ════════════════════════════════════════════════════════════
# Configuración de Producción — TEMPLATE
# ════════════════════════════════════════════════════════════
# Copiar a .env y ajustar valores.
# OPCIONAL: SECRET_KEY puede ir en instance/secret.key (recomendado)
# para que sea inmune a git pull.
# ════════════════════════════════════════════════════════════

# SECRET_KEY puede ir aquí O en instance/secret.key
# Si ponés ambas, esta tiene prioridad.
SECRET_KEY=your-secure-secret-key-here-change-in-production

PROD_HOST=0.0.0.0
PROD_PORT=5001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asis_hos
DB_USER=postgres
DB_PASSWORD=postgres

# Genderize API
GENDERIZE_API_KEY=tu-api-key-aqui
