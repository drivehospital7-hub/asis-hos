# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales
venv/
.venv/
env/

# =========================
# Flask
# =========================
instance/
.webassets-cache

# =========================
# Configuración sensible
# =========================
.env
.env.*
config.py

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Archivos del sistema
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editores
# =========================
.vscode/
.idea/

# =========================
# Tests / coverage
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# Build / dist
# =========================
build/
dist/
*.egg-info/

# =========================
# Archivos temporales
# =========================
*.tmp
*.bak
*.swp

# =========================
# Archivos temporales de debug/exploración
# =========================
header_check.txt
header_check2.txt

# =========================
# Data de importación (no versionar)
# =========================
data/import/

# =========================
# Exports generados (no versionar)
# =========================
data/export/notas_tecnicas_export.csv

# =========================
# DATA (CRÍTICO EN TU PROYECTO)
# =========================

# Ignorar todo el data por defecto
app/data/*

# Pero mantener estructura de carpetas
!app/data/.gitkeep
!app/data/input/
!app/data/output/

# Mantener carpetas vacías
app/data/input/*
app/data/output/*

# Excepto archivos placeholder
!app/data/input/.gitkeep
!app/data/output/.gitkeep

# =========================
# Scripts ejecutados manualmente (opcional logs/output)
# =========================
scripts/*.log
scripts/output/

# =========================
# Base de datos (cuando la agregues)
# =========================
*.db
*.sqlite3

# =========================
# Windows Zone Identifiers (ADS de NTFS en WSL)
# =========================
*:Zone.Identifier

# =========================
# Frontend (Vite / React / npm)
# =========================
frontend/node_modules/
frontend/dist/
*.tsbuildinfo

# =========================
# React build output served by Flask (keep tracked)
# app/static/react-dist/

# =========================
# Agent / SDD artifacts
# =========================
.atl/