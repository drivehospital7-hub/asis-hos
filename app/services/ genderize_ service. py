"""Servicio para consumir Genderize API con urllib."""
import json
import logging
import re
from dataclasses import dataclass
from typing import Any
from urllib.error import HTTPError
from urllib.parse import urlencode
from urllib.request import urlopen

logger = logging.getLogger(__name__)
GENDERIZE_API_URL = "https://api.genderize.io"

# Patrones para detectar "Hijo de" / "Hija de"
_RE_HIJO = re.compile(r"^Hijo de\s+", re.IGNORECASE)
_RE_HIJA = re.compile(r"^Hija de\s+", re.IGNORECASE)


@dataclass
class GenderResult:
    """Resultado de genderize para un nombre."""

    name: str
    gender: str | None
    probability: float | None
    count: int | None


def predict_genders(names: list[str]) -> list[GenderResult]:
    """Obtiene predicciones de género para una lista de nombres.

    Args:
        names: Lista de nombres (máximo 10).

    Returns:
        Lista de GenderResult con las predicciones. El género se fuerza a 'male'
        cuando el nombre tiene prefijo "Hijo de" / "hijo de", o a 'female'
        cuando tiene "Hija de" / "hija de".
    """
    if not names:
        return []

    # Clasificar cada nombre: normal, "hijo de X", "hija de X"
    classified: list[tuple[str, str | None]] = []
    for name in names:
        if _RE_HIJO.match(name):
            classified.append((name, "male"))
        elif _RE_HIJA.match(name):
            classified.append((name, "female"))
        else:
            classified.append((name, None))

    # Batch API con los nombres reales
    names_batch = [name for name, _ in classified]
    params = [(f"name[{i}]", name) for i, name in enumerate(names_batch)]
    query = urlencode(params)
    url = f"{GENDERIZE_API_URL}?{query}"

    logger.info("Consultando genderize para %d nombres", len(names_batch))

    try:
        with urlopen(url, timeout=30) as response:
            data: list[dict[str, Any]] = json.load(response)
    except HTTPError as e:
        logger.exception("Error HTTP genderize: %s", e.code)
        raise

    # Mapear resultados por nombre
    data_by_name = {item["name"]: item for item in data}

    results = []
    for name, forced_gender in classified:
        item = data_by_name.get(name, {})
        gender = forced_gender if forced_gender else item.get("gender")
        results.append(
            GenderResult(
                name=name,
                gender=gender,
                probability=item.get("probability"),
                count=item.get("count"),
            )
        )

    logger.info("Recibidos %d resultados", len(results))
    return results